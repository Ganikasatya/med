# Copy to .env and adjust. All values have sensible dev defaults in app/config.py.

# --- Database ---
# Local dev (default): a SQLite file in this directory.
# DATABASE_URL=sqlite:///./tapcure.db
# Production examples:
# MySQL 8 (deck's target):  DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/tapcure
# PostgreSQL:               DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/tapcure
DATABASE_URL=postgresql+psycopg2://postgres:Lakshmi%405@localhost:5432/med
# --- Auth ---
# MUST be set to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Behaviour ---
SEED_ON_STARTUP=true
DEBUG=true

# --- Voice assistant (Book by Voice) ---
# Leave blank to use the free on-device browser voice.
# OPENAI_API_KEY=sk-...
# STT_PROVIDER=openai  # openai or deepgram
# DEEPGRAM_API_KEY=dg_...
# DEEPGRAM_MODEL=nova-3

# --- Text-to-speech (Cartesia Sonic — natural Telugu/Hindi voices) ---
# Both REQUIRED to turn cloud TTS on; one Sonic voice speaks every language.
# CARTESIA_API_KEY=sk_car_...
# CARTESIA_VOICE_ID=

# --- Email (SMTP) ---
# Set MAIL_ENABLED=true and fill these to send real email; otherwise mail is
# mocked (DB-logged only). For Gmail, SMTP_PASSWORD is a 16-char App Password
# (Google account -> Security -> 2-Step Verification -> App passwords), NOT the
# normal account password.
MAIL_ENABLED=false
MAIL_PROVIDER=smtp
MAIL_FROM_EMAIL=you@example.com
MAIL_FROM_NAME=TapCure
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
