# Copy to .env and adjust. All values have sensible dev defaults in app/config.py.

# --- Database ---
# Local dev (default): a SQLite file in this directory.
# DATABASE_URL=sqlite:///./ruralop.db
# Production examples:
# MySQL 8 (deck's target):  DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/ruralop
# PostgreSQL:               DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ruralop
DATABASE_URL=postgresql+psycopg2://postgres:Lakshmi%405@localhost:5432/med
# --- Auth ---
# MUST be set to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Behaviour ---
SEED_ON_STARTUP=true
DEBUG=true
